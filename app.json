{
  "expo": {
    "name": "Bubbly-fi Laundry",
    "slug": "bubbly-fi",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "bubblyfi",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bubblyfi.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Bubbly-fi uses your location to estimate delivery ETA when you choose delivery instead of counter drop-off."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7FAFC"
      },
      "package": "com.bubblyfi.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Bubbly-fi uses your location only while booking or tracking delivery."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#F7FAFC"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://api.example.com",
      "eas": {
        "projectId": "478788c4-406a-47a3-abbb-bb2aaff2b269"
      }
    },
    "owner": "bubbly-fi"
  }
}
